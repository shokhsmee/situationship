# ─── Postgres ────────────────────────────────────────────────
POSTGRES_USER=situationship
POSTGRES_PASSWORD=situationship
POSTGRES_DB=situationship

# ─── Backend (api) ───────────────────────────────────────────
# Compose builds these from the Postgres/Redis service names; override for
# local (non-Docker) runs.
DATABASE_URL=postgresql+asyncpg://situationship:situationship@postgres:5432/situationship
REDIS_URL=redis://redis:6379/0
DEBUG=false
# CHANGE THIS in production — used to sign JWTs.
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── Telegram ────────────────────────────────────────────────
# From @BotFather. Required for the bot and for Mini App initData validation.
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL of the Mini App (the frontend). Telegram requires HTTPS.
# Local: http://localhost. Production: set via SITE_DOMAIN below (the prod
# compose derives TELEGRAM_WEBAPP_URL=https://$SITE_DOMAIN automatically).
TELEGRAM_WEBAPP_URL=http://localhost

# ─── Production TLS edge (docker-compose.prod.yml / Caddy) ───
# Your domain (A record → server IP). Caddy auto-issues a Let's Encrypt cert.
SITE_DOMAIN=game.example.com
# Email for Let's Encrypt expiry notices (optional but recommended).
ACME_EMAIL=you@example.com

# ─── Bot ─────────────────────────────────────────────────────
API_BASE_URL=http://api:8000/api/v1

# ─── Gameplay defaults (seconds) ─────────────────────────────
DEFAULT_INTRO_SECONDS=60
DEFAULT_EVIDENCE_SECONDS=90
DEFAULT_DISCUSSION_SECONDS=120
DEFAULT_VOTE_SECONDS=60
DEFAULT_ROUNDS=2
